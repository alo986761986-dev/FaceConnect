import { useState } from "react";
import { motion, AnimatePresence } from "framer-motion";
import { useNavigate } from "react-router-dom";
import { 
  ArrowLeft, ChevronRight, User, Lock, Shield, Link2, 
  Download, Search, Globe, Smartphone, Bell, Clock, 
  Users, UserX, MapPin, MessageCircle, AtSign, Heart,
  Eye, EyeOff, Bookmark, Archive, Activity, Star,
  VolumeX, Settings as SettingsIcon, HardDrive, Accessibility,
  Languages, Wifi, AppWindow, HelpCircle, Info, LogOut,
  Plus, UserPlus, Share2, Facebook, Instagram, Mail,
  Fingerprint, History, Monitor, Key, CheckCircle, AlertTriangle,
  Image, Upload, Trash2, Database, Film, Radio, X, FileText
} from "lucide-react";
import { Button } from "@/components/ui/button";
import { Switch } from "@/components/ui/switch";
import { ScrollArea } from "@/components/ui/scroll-area";
import { Avatar, AvatarFallback, AvatarImage } from "@/components/ui/avatar";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { toast } from "sonner";
import { useAuth } from "@/context/AuthContext";
import { useSettings } from "@/context/SettingsContext";
import { haptic } from "@/utils/mobile";
import BottomNav from "@/components/BottomNav";

const API_URL = process.env.REACT_APP_BACKEND_URL;

// Settings Item Component
const SettingsItem = ({ icon: Icon, title, subtitle, onClick, rightElement, color = "#00F0FF", danger = false }) => {
  const { isDark } = useSettings();
  return (
    <button
      onClick={() => { haptic.light(); onClick?.(); }}
      className={`w-full flex items-center gap-3 p-3 rounded-xl transition-colors ${
        isDark ? 'hover:bg-white/5' : 'hover:bg-gray-50'
      } ${danger ? 'text-red-500' : ''}`}
    >
      <div className={`w-10 h-10 rounded-full flex items-center justify-center ${
        danger ? 'bg-red-500/20' : ''
      }`} style={{ backgroundColor: danger ? undefined : `${color}20` }}>
        <Icon className="w-5 h-5" style={{ color: danger ? '#ef4444' : color }} />
      </div>
      <div className="flex-1 text-left">
        <p className={`font-medium ${isDark ? 'text-white' : 'text-gray-900'} ${danger ? 'text-red-500' : ''}`}>
          {title}
        </p>
        {subtitle && (
          <p className={`text-sm ${isDark ? 'text-gray-500' : 'text-gray-500'}`}>{subtitle}</p>
        )}
      </div>
      {rightElement || <ChevronRight className={`w-5 h-5 ${isDark ? 'text-gray-600' : 'text-gray-400'}`} />}
    </button>
  );
};

// Section Header
const SectionHeader = ({ title }) => {
  const { isDark } = useSettings();
  return (
    <h3 className={`px-3 py-2 text-xs font-semibold uppercase tracking-wider ${isDark ? 'text-gray-500' : 'text-gray-400'}`}>
      {title}
    </h3>
  );
};

// Sub-window wrapper component
const SubWindow = ({ isOpen, onClose, title, children }) => {
  const { isDark } = useSettings();
  
  return (
    <AnimatePresence>
      {isOpen && (
        <motion.div
          initial={{ x: "100%" }}
          animate={{ x: 0 }}
          exit={{ x: "100%" }}
          transition={{ type: "spring", damping: 25, stiffness: 300 }}
          className={`fixed inset-0 z-[100] ${isDark ? 'bg-[#0A0A0A]' : 'bg-gray-50'}`}
        >
          {/* Header */}
          <div className={`sticky top-0 z-10 flex items-center gap-3 px-4 py-3 ${isDark ? 'bg-[#0A0A0A]/95' : 'bg-white/95'} backdrop-blur-lg border-b ${isDark ? 'border-white/10' : 'border-gray-200'}`}>
            <button onClick={onClose} className="p-2 -ml-2 rounded-full hover:bg-white/10">
              <ArrowLeft className={`w-5 h-5 ${isDark ? 'text-white' : 'text-gray-900'}`} />
            </button>
            <h1 className={`text-lg font-semibold ${isDark ? 'text-white' : 'text-gray-900'}`}>{title}</h1>
          </div>
          
          {/* Content */}
          <ScrollArea className="h-[calc(100vh-60px)]">
            <div className="p-4 pb-24">
              {children}
            </div>
          </ScrollArea>
        </motion.div>
      )}
    </AnimatePresence>
  );
};

export default function SettingsPage() {
  const navigate = useNavigate();
  const { user, logout } = useAuth();
  const { isDark, settings, updateSettings, t } = useSettings();
  
  // Sub-window states
  const [activeWindow, setActiveWindow] = useState(null);
  
  const openWindow = (windowName) => {
    haptic.medium();
    setActiveWindow(windowName);
  };
  
  const closeWindow = () => {
    haptic.light();
    setActiveWindow(null);
  };

  const handleLogout = async () => {
    haptic.heavy();
    await logout();
    navigate("/auth");
    toast.success("Logged out successfully");
  };

  return (
    <div className={`min-h-screen ${isDark ? 'bg-[#0A0A0A]' : 'bg-gray-50'}`}>
      {/* Header */}
      <div className={`sticky top-0 z-50 px-4 py-3 ${isDark ? 'bg-[#0A0A0A]/95' : 'bg-white/95'} backdrop-blur-lg border-b ${isDark ? 'border-white/10' : 'border-gray-200'}`}>
        <div className="flex items-center gap-3">
          <button onClick={() => navigate(-1)} className="p-2 -ml-2 rounded-full hover:bg-white/10">
            <ArrowLeft className={`w-5 h-5 ${isDark ? 'text-white' : 'text-gray-900'}`} />
          </button>
          <h1 className={`text-xl font-bold ${isDark ? 'text-white' : 'text-gray-900'}`}>Settings</h1>
        </div>
      </div>

      <ScrollArea className="h-[calc(100vh-120px)]">
        <div className="p-4 space-y-6 pb-32">
          
          {/* User Profile Card */}
          <div className={`p-4 rounded-2xl ${isDark ? 'bg-[#121212]' : 'bg-white'}`}>
            <div className="flex items-center gap-4">
              <Avatar className="w-16 h-16 border-2 border-[#00F0FF]">
                <AvatarImage src={user?.avatar ? `${API_URL}${user.avatar}` : undefined} />
                <AvatarFallback className="bg-gradient-to-br from-[#00F0FF] to-[#7000FF] text-white text-xl">
                  {user?.display_name?.[0] || user?.username?.[0] || "U"}
                </AvatarFallback>
              </Avatar>
              <div className="flex-1">
                <h2 className={`text-lg font-semibold ${isDark ? 'text-white' : 'text-gray-900'}`}>
                  {user?.display_name || user?.username}
                </h2>
                <p className={`text-sm ${isDark ? 'text-gray-400' : 'text-gray-500'}`}>@{user?.username}</p>
              </div>
            </div>
          </div>

          {/* Account Management Center */}
          <div className={`rounded-2xl overflow-hidden ${isDark ? 'bg-[#121212]' : 'bg-white'}`}>
            <SectionHeader title="Account Management Center" />
            <SettingsItem 
              icon={User} 
              title="Account Management Center"
              subtitle="Manage your account settings"
              onClick={() => openWindow("accountManagement")}
            />
          </div>

          {/* Password and Security */}
          <div className={`rounded-2xl overflow-hidden ${isDark ? 'bg-[#121212]' : 'bg-white'}`}>
            <SectionHeader title="Password and Security" />
            <SettingsItem icon={Lock} title="Change Password" onClick={() => openWindow("changePassword")} />
            <SettingsItem icon={Shield} title="Two-Factor Authentication" onClick={() => openWindow("twoFactor")} />
            <SettingsItem icon={Key} title="Saved Login" onClick={() => openWindow("savedLogin")} />
            <SettingsItem icon={AlertTriangle} title="Security Checks" onClick={() => openWindow("securityChecks")} />
            <SettingsItem icon={Monitor} title="Devices You're Signed In From" onClick={() => openWindow("devices")} />
            <SettingsItem icon={Mail} title="Recent Emails" onClick={() => openWindow("recentEmails")} />
          </div>

          {/* Linked Features */}
          <div className={`rounded-2xl overflow-hidden ${isDark ? 'bg-[#121212]' : 'bg-white'}`}>
            <SectionHeader title="Linked Features" />
            <SettingsItem icon={Share2} title="Share Across Profiles" onClick={() => openWindow("shareProfiles")} />
            <SettingsItem icon={Facebook} title="Facebook Dating and Instagram" color="#1877F2" onClick={() => openWindow("facebookInstagram")} />
          </div>

          {/* Profile Information and Sign In */}
          <div className={`rounded-2xl overflow-hidden ${isDark ? 'bg-[#121212]' : 'bg-white'}`}>
            <SectionHeader title="Profile Information and Sign In" />
            <SettingsItem icon={Image} title="Sync Profile Pictures" onClick={() => openWindow("syncPictures")} />
            <SettingsItem icon={Link2} title="Sign in with Accounts" onClick={() => openWindow("signInAccounts")} />
          </div>

          {/* Your Information and Permissions */}
          <div className={`rounded-2xl overflow-hidden ${isDark ? 'bg-[#121212]' : 'bg-white'}`}>
            <SectionHeader title="Your Information and Permissions" />
            <SettingsItem icon={Download} title="Export Your Information" onClick={() => openWindow("exportInfo")} />
            <SettingsItem icon={Database} title="Access Your Information" onClick={() => openWindow("accessInfo")} />
            <SettingsItem icon={Search} title="Search History" onClick={() => openWindow("searchHistory")} />
            <SettingsItem icon={AppWindow} title="App Connections" onClick={() => openWindow("appConnections")} />
            <SettingsItem icon={Upload} title="Upload Contacts" onClick={() => openWindow("uploadContacts")} />
