          {/* Notifications & Time */}
          <div className={`rounded-2xl overflow-hidden ${isDark ? 'bg-[#121212]' : 'bg-white'}`}>
            <SectionHeader title="Notifications & Time" />
            <SettingsItem icon={Bell} title="Notifications" onClick={() => openWindow("notifications")} />
            <SettingsItem icon={Clock} title="Time Management" onClick={() => openWindow("timeManagement")} />
          </div>

          {/* Privacy */}
          <div className={`rounded-2xl overflow-hidden ${isDark ? 'bg-[#121212]' : 'bg-white'}`}>
            <SectionHeader title="Privacy" />
            <SettingsItem icon={Lock} title="Account Privacy" onClick={() => openWindow("accountPrivacy")} />
            <SettingsItem icon={Star} title="Close Friends" onClick={() => openWindow("closeFriends")} />
            <SettingsItem icon={Share2} title="Cross-Posting" onClick={() => openWindow("crossPosting")} />
            <SettingsItem icon={UserX} title="Blocked Users" onClick={() => openWindow("blockedUsers")} />
            <SettingsItem icon={MapPin} title="History, Live, and Location" onClick={() => openWindow("historyLocation")} />
          </div>

          {/* Interactions */}
          <div className={`rounded-2xl overflow-hidden ${isDark ? 'bg-[#121212]' : 'bg-white'}`}>
            <SectionHeader title="Interactions" />
            <SettingsItem icon={Users} title="Activity in the Friends Tab" onClick={() => openWindow("friendsActivity")} />
            <SettingsItem icon={MessageCircle} title="Messages and Replies to Stories" onClick={() => openWindow("messagesReplies")} />
            <SettingsItem icon={AtSign} title="Tags and Mentions" onClick={() => openWindow("tagsMentions")} />
            <SettingsItem icon={MessageCircle} title="Comments" onClick={() => openWindow("comments")} />
            <SettingsItem icon={EyeOff} title="Restricted" onClick={() => openWindow("restricted")} />
            <SettingsItem icon={Shield} title="Limit Interactions" onClick={() => openWindow("limitInteractions")} />
          </div>

          {/* Following */}
          <div className={`rounded-2xl overflow-hidden ${isDark ? 'bg-[#121212]' : 'bg-white'}`}>
            <SectionHeader title="Following" />
            <SettingsItem icon={UserPlus} title="Follow and Send Friends" onClick={() => openWindow("followFriends")} />
            <SettingsItem icon={Star} title="Favorites" onClick={() => openWindow("favorites")} />
            <SettingsItem icon={VolumeX} title="Muted Accounts" onClick={() => openWindow("mutedAccounts")} />
          </div>

          {/* Content */}
          <div className={`rounded-2xl overflow-hidden ${isDark ? 'bg-[#121212]' : 'bg-white'}`}>
            <SectionHeader title="Content Preferences" />
            <SettingsItem icon={Film} title="Content Preferences" onClick={() => openWindow("contentPreferences")} />
            <SettingsItem icon={Heart} title="Like and Share Count" onClick={() => openWindow("likeShareCount")} />
            <SettingsItem icon={Star} title="Subscriptions" onClick={() => openWindow("subscriptions")} />
          </div>

          {/* Device & Data */}
          <div className={`rounded-2xl overflow-hidden ${isDark ? 'bg-[#121212]' : 'bg-white'}`}>
            <SectionHeader title="Device & Data" />
            <SettingsItem icon={Smartphone} title="Device Permissions" onClick={() => openWindow("devicePermissions")} />
            <SettingsItem icon={HardDrive} title="Storage and Downloads" onClick={() => openWindow("storageDownloads")} />
            <SettingsItem icon={Accessibility} title="Accessibility" onClick={() => openWindow("accessibility")} />
            <SettingsItem icon={Languages} title="Language and Translation" onClick={() => openWindow("languageTranslation")} />
            <SettingsItem icon={Wifi} title="Data Use and Media Quality" onClick={() => openWindow("dataUse")} />
            <SettingsItem icon={AppWindow} title="Allow Apps and Websites" onClick={() => openWindow("allowApps")} />
          </div>

          {/* Help & Info */}
          <div className={`rounded-2xl overflow-hidden ${isDark ? 'bg-[#121212]' : 'bg-white'}`}>
            <SectionHeader title="Help & Info" />
            <SettingsItem icon={HelpCircle} title="Help" onClick={() => openWindow("help")} />
            <SettingsItem icon={Shield} title="Privacy Center" onClick={() => openWindow("privacyCenter")} />
            <SettingsItem icon={CheckCircle} title="Account Status" onClick={() => openWindow("accountStatus")} />
            <SettingsItem icon={Info} title="About" onClick={() => openWindow("about")} />
          </div>

          {/* Account Actions */}
          <div className={`rounded-2xl overflow-hidden ${isDark ? 'bg-[#121212]' : 'bg-white'}`}>
            <SettingsItem icon={Plus} title="Add Account" color="#00FF88" onClick={() => openWindow("addAccount")} />
            <SettingsItem icon={LogOut} title="Log Out" danger onClick={handleLogout} />
          </div>

        </div>
      </ScrollArea>

      {/* Sub Windows */}
      <AccountManagementWindow isOpen={activeWindow === "accountManagement"} onClose={closeWindow} />
      <ChangePasswordWindow isOpen={activeWindow === "changePassword"} onClose={closeWindow} />
      <TwoFactorWindow isOpen={activeWindow === "twoFactor"} onClose={closeWindow} />
      <SavedLoginWindow isOpen={activeWindow === "savedLogin"} onClose={closeWindow} />
      <SecurityChecksWindow isOpen={activeWindow === "securityChecks"} onClose={closeWindow} />
      <DevicesWindow isOpen={activeWindow === "devices"} onClose={closeWindow} />
      <RecentEmailsWindow isOpen={activeWindow === "recentEmails"} onClose={closeWindow} />
      <ShareProfilesWindow isOpen={activeWindow === "shareProfiles"} onClose={closeWindow} />
      <FacebookInstagramWindow isOpen={activeWindow === "facebookInstagram"} onClose={closeWindow} />
      <SyncPicturesWindow isOpen={activeWindow === "syncPictures"} onClose={closeWindow} />
      <SignInAccountsWindow isOpen={activeWindow === "signInAccounts"} onClose={closeWindow} />
      <ExportInfoWindow isOpen={activeWindow === "exportInfo"} onClose={closeWindow} />
      <AccessInfoWindow isOpen={activeWindow === "accessInfo"} onClose={closeWindow} />
      <SearchHistoryWindow isOpen={activeWindow === "searchHistory"} onClose={closeWindow} />
      <AppConnectionsWindow isOpen={activeWindow === "appConnections"} onClose={closeWindow} />
      <UploadContactsWindow isOpen={activeWindow === "uploadContacts"} onClose={closeWindow} />
      <AdPreferencesWindow isOpen={activeWindow === "adPreferences"} onClose={closeWindow} />
      <AddAccountWindow isOpen={activeWindow === "addAccount"} onClose={closeWindow} />
      <SavedWindow isOpen={activeWindow === "saved"} onClose={closeWindow} />
      <ArchiveWindow isOpen={activeWindow === "archive"} onClose={closeWindow} />
      <YourActivityWindow isOpen={activeWindow === "yourActivity"} onClose={closeWindow} />
      <NotificationsWindow isOpen={activeWindow === "notifications"} onClose={closeWindow} />
      <TimeManagementWindow isOpen={activeWindow === "timeManagement"} onClose={closeWindow} />
      <AccountPrivacyWindow isOpen={activeWindow === "accountPrivacy"} onClose={closeWindow} />
      <CloseFriendsWindow isOpen={activeWindow === "closeFriends"} onClose={closeWindow} />
      <CrossPostingWindow isOpen={activeWindow === "crossPosting"} onClose={closeWindow} />
      <BlockedUsersWindow isOpen={activeWindow === "blockedUsers"} onClose={closeWindow} />
      <HistoryLocationWindow isOpen={activeWindow === "historyLocation"} onClose={closeWindow} />
      <FriendsActivityWindow isOpen={activeWindow === "friendsActivity"} onClose={closeWindow} />
      <MessagesRepliesWindow isOpen={activeWindow === "messagesReplies"} onClose={closeWindow} />
      <TagsMentionsWindow isOpen={activeWindow === "tagsMentions"} onClose={closeWindow} />
      <CommentsWindow isOpen={activeWindow === "comments"} onClose={closeWindow} />
      <RestrictedWindow isOpen={activeWindow === "restricted"} onClose={closeWindow} />
      <LimitInteractionsWindow isOpen={activeWindow === "limitInteractions"} onClose={closeWindow} />
      <FollowFriendsWindow isOpen={activeWindow === "followFriends"} onClose={closeWindow} />
      <FavoritesWindow isOpen={activeWindow === "favorites"} onClose={closeWindow} />
      <MutedAccountsWindow isOpen={activeWindow === "mutedAccounts"} onClose={closeWindow} />
      <ContentPreferencesWindow isOpen={activeWindow === "contentPreferences"} onClose={closeWindow} />
      <LikeShareCountWindow isOpen={activeWindow === "likeShareCount"} onClose={closeWindow} />
      <SubscriptionsWindow isOpen={activeWindow === "subscriptions"} onClose={closeWindow} />
      <DevicePermissionsWindow isOpen={activeWindow === "devicePermissions"} onClose={closeWindow} />
      <StorageDownloadsWindow isOpen={activeWindow === "storageDownloads"} onClose={closeWindow} />
      <AccessibilityWindow isOpen={activeWindow === "accessibility"} onClose={closeWindow} />
      <LanguageTranslationWindow isOpen={activeWindow === "languageTranslation"} onClose={closeWindow} />
      <DataUseWindow isOpen={activeWindow === "dataUse"} onClose={closeWindow} />
      <AllowAppsWindow isOpen={activeWindow === "allowApps"} onClose={closeWindow} />
      <HelpWindow isOpen={activeWindow === "help"} onClose={closeWindow} />
      <PrivacyCenterWindow isOpen={activeWindow === "privacyCenter"} onClose={closeWindow} />
      <AccountStatusWindow isOpen={activeWindow === "accountStatus"} onClose={closeWindow} />
      <AboutWindow isOpen={activeWindow === "about"} onClose={closeWindow} />

      <BottomNav />
    </div>
  );
}

// ============== SUB-WINDOW COMPONENTS ==============

// Account Management Window
function AccountManagementWindow({ isOpen, onClose }) {
  const { isDark } = useSettings();
  return (
    <SubWindow isOpen={isOpen} onClose={onClose} title="Account Management Center">
      <div className="space-y-4">
        <div className={`p-4 rounded-xl ${isDark ? 'bg-[#121212]' : 'bg-white'}`}>
          <h3 className={`font-semibold mb-3 ${isDark ? 'text-white' : 'text-gray-900'}`}>Account Overview</h3>
          <p className={`text-sm ${isDark ? 'text-gray-400' : 'text-gray-500'}`}>
            Manage your FaceConnect account settings, security, and connected services from this central hub.
          </p>
        </div>
        <SettingsItem icon={User} title="Personal Information" subtitle="Name, email, phone" />
        <SettingsItem icon={Shield} title="Security Settings" subtitle="Password, 2FA, devices" />
        <SettingsItem icon={Link2} title="Connected Accounts" subtitle="Social media links" />
        <SettingsItem icon={Trash2} title="Delete Account" subtitle="Permanently remove account" danger />
      </div>
    </SubWindow>
  );
}

// Change Password Window
function ChangePasswordWindow({ isOpen, onClose }) {
  const { isDark } = useSettings();
  const [currentPassword, setCurrentPassword] = useState("");
  const [newPassword, setNewPassword] = useState("");
  const [confirmPassword, setConfirmPassword] = useState("");

  const handleChangePassword = () => {
    if (newPassword !== confirmPassword) {
      toast.error("Passwords don't match");
      return;
    }
    toast.success("Password changed successfully");
    onClose();
  };

  return (
    <SubWindow isOpen={isOpen} onClose={onClose} title="Change Password">
      <div className="space-y-4">
        <div>
          <Label className={isDark ? 'text-gray-400' : ''}>Current Password</Label>
          <Input 
            type="password" 
            value={currentPassword} 
            onChange={(e) => setCurrentPassword(e.target.value)}
            className={`mt-1 ${isDark ? 'bg-[#1A1A1A] border-white/10 text-white' : ''}`}
          />
        </div>
        <div>
          <Label className={isDark ? 'text-gray-400' : ''}>New Password</Label>
          <Input 
            type="password" 
            value={newPassword} 
            onChange={(e) => setNewPassword(e.target.value)}
            className={`mt-1 ${isDark ? 'bg-[#1A1A1A] border-white/10 text-white' : ''}`}
          />
        </div>
        <div>
          <Label className={isDark ? 'text-gray-400' : ''}>Confirm New Password</Label>
          <Input 
            type="password" 
            value={confirmPassword} 
            onChange={(e) => setConfirmPassword(e.target.value)}
            className={`mt-1 ${isDark ? 'bg-[#1A1A1A] border-white/10 text-white' : ''}`}
          />
        </div>
        <Button onClick={handleChangePassword} className="w-full bg-gradient-to-r from-[#00F0FF] to-[#7000FF]">
          Change Password
        </Button>
      </div>
    </SubWindow>
  );
}

// Two Factor Authentication Window
function TwoFactorWindow({ isOpen, onClose }) {
  const { isDark, settings, updateSettings } = useSettings();
  return (
    <SubWindow isOpen={isOpen} onClose={onClose} title="Two-Factor Authentication">
      <div className="space-y-4">
        <div className={`p-4 rounded-xl ${isDark ? 'bg-[#121212]' : 'bg-white'}`}>
          <div className="flex items-center justify-between">
            <div>
              <p className={`font-medium ${isDark ? 'text-white' : 'text-gray-900'}`}>Enable 2FA</p>
              <p className={`text-sm ${isDark ? 'text-gray-400' : 'text-gray-500'}`}>Add extra security to your account</p>
            </div>
            <Switch checked={settings?.twoFactorEnabled || false} onCheckedChange={(val) => updateSettings({ twoFactorEnabled: val })} />
          </div>
        </div>
        <SettingsItem icon={Smartphone} title="Authenticator App" subtitle="Use Google Authenticator or similar" />
        <SettingsItem icon={MessageCircle} title="SMS Verification" subtitle="Receive codes via text message" />
        <SettingsItem icon={Mail} title="Email Verification" subtitle="Receive codes via email" />
      </div>
    </SubWindow>
  );
}

// Saved Login Window
function SavedLoginWindow({ isOpen, onClose }) {
  const { isDark } = useSettings();
  return (
    <SubWindow isOpen={isOpen} onClose={onClose} title="Saved Login">
      <div className="space-y-4">
        <div className={`p-4 rounded-xl ${isDark ? 'bg-[#121212]' : 'bg-white'}`}>
          <p className={`text-sm ${isDark ? 'text-gray-400' : 'text-gray-500'}`}>
            When you save your login info, you won't need to enter it every time you log in.
          </p>
        </div>
        <div className="flex items-center justify-between p-4 rounded-xl" style={{ backgroundColor: isDark ? '#121212' : 'white' }}>
          <p className={isDark ? 'text-white' : 'text-gray-900'}>Save Login Information</p>
          <Switch defaultChecked />
        </div>
      </div>
    </SubWindow>
  );
}

// Security Checks Window
function SecurityChecksWindow({ isOpen, onClose }) {
  const { isDark } = useSettings();
  return (
    <SubWindow isOpen={isOpen} onClose={onClose} title="Security Checks">
      <div className="space-y-4">
        <div className={`p-4 rounded-xl ${isDark ? 'bg-green-500/10' : 'bg-green-50'} border border-green-500/20`}>
          <div className="flex items-center gap-3">
            <CheckCircle className="w-6 h-6 text-green-500" />
            <div>
              <p className={`font-medium ${isDark ? 'text-white' : 'text-gray-900'}`}>Your account is secure</p>
              <p className={`text-sm ${isDark ? 'text-gray-400' : 'text-gray-500'}`}>No security issues found</p>
            </div>
          </div>
        </div>
        <SettingsItem icon={Lock} title="Password Strength" subtitle="Strong" />
        <SettingsItem icon={Shield} title="Two-Factor Status" subtitle="Enabled" />
        <SettingsItem icon={Mail} title="Email Verified" subtitle="Verified" />
        <SettingsItem icon={Smartphone} title="Phone Verified" subtitle="Not verified" />
      </div>
    </SubWindow>
  );
}

// Devices Window
function DevicesWindow({ isOpen, onClose }) {
  const { isDark } = useSettings();
  return (
    <SubWindow isOpen={isOpen} onClose={onClose} title="Devices You're Signed In From">
