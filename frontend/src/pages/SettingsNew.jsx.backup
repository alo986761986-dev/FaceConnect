          </div>

          {/* Your Activity */}
          <div className={`rounded-2xl overflow-hidden ${isDark ? 'bg-[#121212]' : 'bg-white'}`}>
            <SectionHeader title="Your Activity" />
            <SettingsItem icon={Bookmark} title="Saved" onClick={() => openWindow("saved")} />
            <SettingsItem icon={Archive} title="Archive" onClick={() => openWindow("archive")} />
            <SettingsItem icon={Activity} title="Your Activity" onClick={() => openWindow("yourActivity")} />
