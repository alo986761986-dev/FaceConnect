{
  "identity": {
    "name": "E1",
    "persona": "The Modernist",
    "description": "A design philosophy that prioritizes content over chrome. Exaggerated minimalism, 'Swiss' clarity, and 'Cinema' immersion."
  },
  "typography": {
    "font_family": {
      "headings": "Syne, sans-serif",
      "body": "Manrope, sans-serif",
      "mono": "JetBrains Mono, monospace"
    },
    "weights": {
      "light": 300,
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "extrabold": 800
    },
    "styles": {
      "h1": "font-family: 'Syne'; font-weight: 700; font-size: 2.5rem; letter-spacing: -0.02em; line-height: 1.1;",
      "h2": "font-family: 'Syne'; font-weight: 700; font-size: 2rem; letter-spacing: -0.01em; line-height: 1.2;",
      "h3": "font-family: 'Syne'; font-weight: 600; font-size: 1.5rem; letter-spacing: -0.01em;",
      "body_lg": "font-family: 'Manrope'; font-size: 1.125rem; line-height: 1.6;",
      "body_base": "font-family: 'Manrope'; font-size: 1rem; line-height: 1.5;",
      "caption": "font-family: 'Manrope'; font-size: 0.875rem; color: var(--text-muted);"
    }
  },
  "colors": {
    "palette": {
      "primary": {
        "main": "#2D5BFF",
        "light": "#6B8AFF",
        "dark": "#0029CC",
        "contrast": "#FFFFFF"
      },
      "secondary": {
        "main": "#1A1A1A",
        "light": "#333333",
        "dark": "#000000",
        "contrast": "#FFFFFF"
      },
      "accent": {
        "cyan": "#00F0FF",
        "purple": "#7C3AED",
        "success": "#10B981",
        "error": "#EF4444"
      },
      "background": {
        "light": "#FFFFFF",
        "light_subtle": "#F8F9FA",
        "dark": "#0A0A0A",
        "dark_subtle": "#121212"
      },
      "text": {
        "light_primary": "#0A0A0A",
        "light_secondary": "#666666",
        "dark_primary": "#EDEDED",
        "dark_secondary": "#A1A1AA"
