  "accessibility": {
    "contrast": "Ensure WCAG AA compliance (4.5:1) for text.",
    "touch_targets": "Minimum 44x44px for all interactive elements.",
    "motion": "Respect prefers-reduced-motion media query."
  },
  "instructions_to_main_agent": [
    "OVERWRITE the existing 'Neo-Noir' theme in index.css. It is too dark/hacker-like for the requested 'Clean Social' vibe.",
    "Implement a 'Theme Toggle' (Light/Dark). Default to System.",
    "Use 'Syne' font ONLY for large headings (h1, h2). Use 'Manrope' for everything else.",
    "Do not use generic 'Card' components for the Feed. Make posts feel like they are part of a continuous flow (minimal borders).",
    "Ensure the 'FaceScan' feature looks professional and secure (banking app style), not like a video game.",
    "Use the provided image URLs for placeholders. Do not use colored divs.",
    "For the 'Create' button in the bottom nav, make it distinct (e.g., solid primary color circle)."
  ],
  "UNIVERSAL_GUIDELINES": [
    "Dark colors look good when used independently without gradients. DO NOT use dark colors as gradients",
    "Don't make generic centered layouts, simplistic gradients, and uniform styling.",
    "Create depth through layered design elements with z-index hierarchy",
    "Use glass-morphism effects with backdrop filters (12-24px blur)",
    "You MUST NOT apply universal transition. Eg: transition: all. This results in breaking transforms.",
    "You MUST NOT center align the app container, ie do not add .App { text-align: center; }",
    "Always use modern button styles like pill-shaped, or sharp button with interaction animations",
    "NEVER use AI assistant Emoji characters like 🤖🧠 for icons.",
    "Every interaction needs micro-animations - hover states, transitions.",
    "Use sonner for toasts."
  ]
}